# Copy to .env and set your values
# Required for AI classification
GEMINI_API_KEY=your_gemini_api_key_here

# OAuth client secrets file path
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json

# Default playlist privacy (private|unlisted|public)
DEFAULT_PLAYLIST_PRIVACY=private

# Performance optimization settings
API_CONCURRENCY=6                # Number of concurrent API read operations
API_RPS=8                        # API requests per second limit  
BATCH_SIZE=50                    # Batch size for API operations (max 50)
LLM_CONCURRENCY=8                # Concurrent LLM classification requests
CACHE_DIR=.cache/ytpo           # Directory for caching data
ENABLE_CACHE=true               # Enable classification and membership caching
ENABLE_STATE=true               # Enable state tracking of processed videos

# Rate limiting
API_DELAY_SECONDS=0.0           # Additional delay between API calls

